# ============================================
# Application
# ============================================
APP_ENV=development
DEBUG=true
APP_SECRET_KEY=CHANGE_ME_super_secret_key_at_least_32_characters_long
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Produção (same-origin Coolify):
# ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# ============================================
# Database
# ============================================
# Desenvolvimento (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Produção (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://sist_alugueis:CHANGE_ME@localhost:5432/sist_alugueis
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# ============================================
# PostgreSQL (produção)
# ============================================
POSTGRES_USER=sist_alugueis
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sist_alugueis
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
