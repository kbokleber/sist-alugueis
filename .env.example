# ============================================
# PRODUÇÃO - Exemplo de Variáveis de Ambiente
# ============================================

# PostgreSQL
POSTGRES_USER=sist_alugueis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sist_alugueis

# JWT (mínimo 32 caracteres)
JWT_SECRET_KEY=CHANGE_ME_32_CHARACTERS_SECRET_KEY

# CORS - Origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# Frontend
VITE_API_BASE_URL=https://api.seu-dominio.com
VITE_APP_NAME=Sistema de Aluguéis

# Porta do frontend (opcional, padrão 3000)
FRONTEND_PORT=3000

# Tempos de expiração (opcional)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
